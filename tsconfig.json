{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true,
		"lib": ["esnext", "DOM", "DOM.Iterable"],
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"module": "esnext",
		"target": "esnext",
		"strict": true
	},
	"include": ["src/lib"],
	"exclude": ["dist"]
}
