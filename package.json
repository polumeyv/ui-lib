{
	"name": "@polumeyv/ui",
	"version": "0.0.10",
	"description": "Svelte 5 UI component library with Tailwind CSS",
	"publishConfig": {
		"access": "public",
		"registry": "https://npm.pkg.github.com"
	},
	"license": "MIT",
	"keywords": ["svelte", "ui", "components", "tailwind"],
	"type": "module",
	"repository": "github:polumeyv/ui-lib",
	"svelte": "./src/lib/components/index.ts",
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"release": "npx changelogen --release --push"
	},
	"bin": {
		"ui": "./bin/init.mjs"
	},
	"files": [
		"src/lib",
		"bin"
	],
	"exports": {
		".": {
			"types": "./src/lib/components/index.ts",
			"svelte": "./src/lib/components/index.ts",
			"default": "./src/lib/components/index.ts"
		},
		"./blocks": {
			"types": "./src/lib/blocks/index.ts",
			"svelte": "./src/lib/blocks/index.ts",
			"default": "./src/lib/blocks/index.ts"
		},
		"./hooks": {
			"types": "./src/lib/hooks/index.ts",
			"svelte": "./src/lib/hooks/index.ts",
			"default": "./src/lib/hooks/index.ts"
		},
		"./layout": {
			"types": "./src/lib/layout/index.ts",
			"svelte": "./src/lib/layout/index.ts",
			"default": "./src/lib/layout/index.ts"
		},
		"./utils": {
			"types": "./src/lib/utils.ts",
			"default": "./src/lib/utils.ts"
		},
		"./format": {
			"types": "./src/lib/format/index.ts",
			"default": "./src/lib/format/index.ts"
		},
		"./icons": {
			"types": "./src/lib/icons/index.ts",
			"svelte": "./src/lib/icons/index.ts",
			"default": "./src/lib/icons/index.ts"
		},
		"./styles": "./src/lib/assets/layout.css",
		"./fonts": "./src/lib/assets/fonts.css"
	},
	"peerDependencies": {
		"svelte": "catalog:"
	},
	"dependencies": {
		"@lucide/svelte": "catalog:ui",
		"@tanstack/table-core": "catalog:ui",
		"bits-ui": "catalog:ui",
		"clsx": "catalog:styling",
		"d3-scale": "catalog:ui",
		"embla-carousel-svelte": "catalog:ui",
		"layerchart": "catalog:ui",
		"mode-watcher": "catalog:ui",
		"paneforge": "catalog:ui",
		"svelte-sonner": "catalog:ui",
		"tailwind-merge": "catalog:styling",
		"tailwind-variants": "catalog:styling",
		"vaul-svelte": "catalog:ui",
		"dinero.js": "catalog:infra"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"tw-animate-css": "catalog:styling",
		"vite": "catalog:"
	}
}