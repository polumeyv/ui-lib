{
	"name": "@polumeyv/ui",
	"version": "0.0.10",
	"description": "Svelte 5 UI component library with Tailwind CSS",
	"publishConfig": {
		"access": "public",
		"registry": "https://npm.pkg.github.com"
	},
	"license": "MIT",
	"keywords": ["svelte", "ui", "components", "tailwind"],
	"type": "module",
	"repository": "github:polumeyv/ui-lib",
	"svelte": "./src/lib/index.ts",
	"sideEffects": [
		"**/*.css"
	],
	"scripts": {
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"release": "npx changelogen --release --push"
	},
	"bin": {
		"ui": "./bin/init.mjs"
	},
	"files": [
		"src/lib",
		"bin"
	],
	"exports": {
		".": {
			"types": "./src/lib/index.ts",
			"svelte": "./src/lib/index.ts",
			"default": "./src/lib/index.ts"
		},
		"./styles": "./src/lib/assets/layout.css"
	},
	"peerDependencies": {
		"svelte": "^5.53.7"
	},
	"dependencies": {
		"@lucide/svelte": "^0.577.0",
		"@tanstack/table-core": "^8.21.3",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"d3-scale": "^4.0.2",
		"embla-carousel-svelte": "^8.6.0",
		"layerchart": "2.0.0-next.46",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"svelte-sonner": "^1.0.8",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"vaul-svelte": "1.0.0-next.7"
	},
	"devDependencies": {
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"tw-animate-css": "^1.4.0",
		"vite": "^8.0.0"
	}
}